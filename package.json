{
  "name": "solana-seeker",
  "version": "1.0.0",
  "private": true,
  "description": "Solana Seeker - Solana-native user engagement, task, XP, ranking, and future airdrop reward platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run dev --workspace=apps/backend",
    "mobile:start": "npm run start --workspace=apps/mobile",
    "admin:dev": "npm run dev --workspace=apps/admin",
    "backend:build": "npm run build --workspace=apps/backend",
    "db:migrate": "npm run prisma:migrate --workspace=apps/backend",
    "db:generate": "npm run prisma:generate --workspace=apps/backend"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
