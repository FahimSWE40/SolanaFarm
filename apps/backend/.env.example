# ============ Database ============
DATABASE_URL="postgresql://postgres:password@localhost:5432/solana_seeker"

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============ Solana ============
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# For Helius: https://rpc.helius.xyz/?api-key=YOUR_KEY
# For QuickNode: https://your-endpoint.quiknode.pro/YOUR_KEY

# ============ Server ============
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:8081,http://localhost:3001

# ============ Firebase (for push notifications) ============
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY="your-private-key"
# FIREBASE_CLIENT_EMAIL=your-client-email
